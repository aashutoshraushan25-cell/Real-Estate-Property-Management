# ---------- EstateHub API environment ----------
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/estatehub?sslmode=require

# Auth
JWT_ACCESS_SECRET=change-me-64-random-chars
JWT_REFRESH_SECRET=change-me-64-random-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret

# Email (nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=secret
EMAIL_FROM="EstateHub <no-reply@estatehub.com>"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
